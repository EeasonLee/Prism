# Zod 验证 + React Hook Form 最佳实践

> Source: [sanjeed5/awesome-cursor-rules-mdc](https://github.com/sanjeed5/awesome-cursor-rules-mdc/blob/main/rules-mdc/zod.mdc)
>
> 本项目已安装 Zod v4 (`zod: ^4.1.13`)

## 1. Schema 定义规范

**集中管理 Schema，放在 `src/schemas/` 或 `src/lib/validations/` 目录：**

```typescript
import { z } from 'zod';

// 基础实体 Schema
export const UserSchema = z.object({
  id: z.string().uuid(),
  name: z.string().min(2, '姓名至少 2 个字符').max(50, '姓名不超过 50 个字符'),
  email: z.string().email('请输入有效的邮箱地址'),
  role: z.enum(['admin', 'editor', 'viewer']),
  createdAt: z.date(),
});

// 从 Schema 推导 TypeScript 类型
export type User = z.infer<typeof UserSchema>;

// 创建操作 Schema（部分字段可选）
export const CreateUserSchema = UserSchema.omit({ id: true, createdAt: true });
export type CreateUserInput = z.infer<typeof CreateUserSchema>;

// 更新操作 Schema（所有字段可选）
export const UpdateUserSchema = CreateUserSchema.partial();
export type UpdateUserInput = z.infer<typeof UpdateUserSchema>;
```

## 2. 表单验证（Zod v4 + React Hook Form）

```tsx
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { z } from 'zod';

import {
  Form, FormControl, FormField, FormItem, FormLabel, FormMessage,
} from '@/components/ui/form';
import { Input } from '@/components/ui/input';
import { Button } from '@/components/ui/button';

const loginSchema = z.object({
  email: z.string().email('请输入有效的邮箱'),
  password: z.string().min(8, '密码至少 8 位'),
});

type LoginInput = z.infer<typeof loginSchema>;

export function LoginForm() {
  const form = useForm<LoginInput>({
    resolver: zodResolver(loginSchema),
    defaultValues: { email: '', password: '' },
  });

  async function onSubmit(data: LoginInput) {
    // data 已经通过类型安全验证
    await authService.login(data);
  }

  return (
    <Form {...form}>
      <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-4">
        <FormField
          control={form.control}
          name="email"
          render={({ field }) => (
            <FormItem>
              <FormLabel>邮箱</FormLabel>
              <FormControl>
                <Input type="email" placeholder="you@example.com" {...field} />
              </FormControl>
              <FormMessage /> {/* 自动显示验证错误 */}
            </FormItem>
          )}
        />
        <FormField
          control={form.control}
          name="password"
          render={({ field }) => (
            <FormItem>
              <FormLabel>密码</FormLabel>
              <FormControl>
                <Input type="password" {...field} />
              </FormControl>
              <FormMessage />
            </FormItem>
          )}
        />
        <Button type="submit" disabled={form.formState.isSubmitting}>
          {form.formState.isSubmitting ? '登录中...' : '登录'}
        </Button>
      </form>
    </Form>
  );
}
```

## 3. API 路由验证（Server Side）

```typescript
// app/api/users/route.ts
import { NextRequest, NextResponse } from 'next/server';
import { z } from 'zod';
import { CreateUserSchema } from '@/schemas/user';

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();

    // 严格验证请求体
    const result = CreateUserSchema.safeParse(body);
    if (!result.success) {
      return NextResponse.json(
        { errors: result.error.flatten().fieldErrors },
        { status: 400 }
      );
    }

    const user = await userService.create(result.data);
    return NextResponse.json(user, { status: 201 });
  } catch (error) {
    return NextResponse.json({ error: '服务器错误' }, { status: 500 });
  }
}
```

## 4. 环境变量验证

```typescript
// src/env.ts - 在应用启动时验证环境变量
import { z } from 'zod';

const envSchema = z.object({
  NODE_ENV: z.enum(['development', 'production', 'test']),
  DATABASE_URL: z.string().url(),
  NEXT_PUBLIC_APP_URL: z.string().url(),
  API_SECRET_KEY: z.string().min(32),
});

export const env = envSchema.parse(process.env);
// 如果验证失败，应用启动时会抛出明确的错误信息
```

## 5. 常用 Zod v4 模式

```typescript
// 可选字段 vs 可为 null
z.string().optional()        // string | undefined
z.string().nullable()        // string | null
z.string().nullish()         // string | null | undefined

// 字符串转换
z.string().trim().toLowerCase()
z.string().url()
z.string().email()
z.string().regex(/^\d{6}$/, '请输入 6 位数字')

// 数字验证
z.number().int().positive()
z.number().min(0).max(100)

// 数组验证
z.array(z.string()).min(1, '至少选择一项').max(10)

// 条件验证（refine）
z.object({
  password: z.string(),
  confirmPassword: z.string(),
}).refine(
  (data) => data.password === data.confirmPassword,
  { message: '两次密码不一致', path: ['confirmPassword'] }
)

// 联合类型
z.discriminatedUnion('type', [
  z.object({ type: z.literal('email'), email: z.string().email() }),
  z.object({ type: z.literal('phone'), phone: z.string() }),
])
```
